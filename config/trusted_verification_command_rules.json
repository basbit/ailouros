[
  {
    "marker": "composer.json",
    "commands": [["composer", "dump-autoload", "-o", "--no-interaction"]]
  },
  {
    "markers": ["pyproject.toml", "setup.py"],
    "commands": [["python", "-m", "py_compile"]]
  },
  {
    "marker": "package.json",
    "commands": [["npm", "run", "--if-present", "build"]]
  },
  {
    "marker": "Cargo.toml",
    "commands": [["cargo", "check"]]
  },
  {
    "marker": "go.mod",
    "commands": [["go", "vet", "./..."]]
  },
  {
    "marker": "Makefile",
    "commands": []
  },
  {
    "marker": "ProjectSettings/ProjectVersion.txt",
    "commands": [["unity", "-batchmode", "-quit", "-projectPath", "."]]
  },
  {
    "marker": "pom.xml",
    "commands": [["mvn", "compile", "-q"]]
  },
  {
    "marker": "build.gradle",
    "commands": [["gradle", "compileJava", "-q"]]
  }
]
