{
  "id": "build_feature",
  "title": "Build Feature",
  "category": "development",
  "description": "Implement a feature in an existing codebase end to end: PM → BA → Architect → spec → DevOps → Dev → QA, with reviewers and a final human gate.",
  "pipeline_steps": [
    "clarify_input",
    "pm",
    "review_pm",
    "ba",
    "review_ba",
    "architect",
    "review_arch",
    "spec_merge",
    "review_spec",
    "devops",
    "review_devops",
    "dev_lead",
    "review_dev_lead",
    "dev",
    "review_dev",
    "qa",
    "review_qa",
    "human_qa"
  ],
  "step_estimates": [
    {"step_id": "clarify_input", "estimated_duration_sec": 30, "essential": true},
    {"step_id": "pm", "estimated_duration_sec": 60, "essential": true},
    {"step_id": "review_pm", "estimated_duration_sec": 30, "essential": false},
    {"step_id": "ba", "estimated_duration_sec": 90, "essential": true},
    {"step_id": "review_ba", "estimated_duration_sec": 30, "essential": false},
    {"step_id": "architect", "estimated_duration_sec": 120, "essential": true},
    {"step_id": "review_arch", "estimated_duration_sec": 45, "essential": false},
    {"step_id": "spec_merge", "estimated_duration_sec": 60, "essential": true},
    {"step_id": "review_spec", "estimated_duration_sec": 45, "essential": false},
    {"step_id": "devops", "estimated_duration_sec": 90, "essential": true},
    {"step_id": "review_devops", "estimated_duration_sec": 30, "essential": false},
    {"step_id": "dev_lead", "estimated_duration_sec": 90, "essential": true},
    {"step_id": "review_dev_lead", "estimated_duration_sec": 30, "essential": false},
    {"step_id": "dev", "estimated_duration_sec": 240, "essential": true},
    {"step_id": "review_dev", "estimated_duration_sec": 60, "essential": false},
    {"step_id": "qa", "estimated_duration_sec": 120, "essential": true},
    {"step_id": "review_qa", "estimated_duration_sec": 45, "essential": false},
    {"step_id": "human_qa", "estimated_duration_sec": 30, "essential": true}
  ],
  "default_gates": ["human_qa"],
  "expected_artifacts": [
    "pipeline.json",
    "agents/pm.txt",
    "agents/ba.txt",
    "agents/architect.txt",
    "agents/dev.txt",
    "agents/qa.txt"
  ],
  "required_tools": ["workspace_write"],
  "workspace_write_default": true,
  "recommended_models": {
    "planner": "strong",
    "review": "fast",
    "dev": "strong"
  },
  "agent_config_defaults": {},
  "tags": ["development", "writes_files", "flagship"],
  "inputs": [
    {
      "key": "prompt",
      "label": "Feature description",
      "hint": "Describe what to build, who it's for, and any constraints.",
      "required": true
    },
    {
      "key": "workspace_root",
      "label": "Workspace path",
      "hint": "Path to the target repository on this machine.",
      "required": true
    },
    {
      "key": "workspace_write",
      "label": "Allow writes to workspace",
      "hint": "The flagship dev flow needs writes enabled."
    },
    {
      "key": "project_context_file",
      "label": "Project context file (optional)",
      "hint": "Path to a markdown file with extra project context."
    }
  ],
  "quality_checks": [
    {
      "id": "core_artifacts_present",
      "type": "artifact_count",
      "severity": "error",
      "blocking": true,
      "config": {"min": 4}
    },
    {
      "id": "dev_output_substantive",
      "type": "agent_output_min_chars",
      "severity": "error",
      "blocking": false,
      "config": {"agent": "dev", "min_chars": 200}
    },
    {
      "id": "qa_output_present",
      "type": "agent_output_min_chars",
      "severity": "warning",
      "blocking": false,
      "config": {"agent": "qa", "min_chars": 50}
    }
  ]
}
