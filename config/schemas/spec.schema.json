{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectSpecification",
  "type": "object",
  "required": ["project_name", "requirements", "tech_stack"],
  "properties": {
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tech_stack": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "deadline": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": false
}

