# Copy as .env and edit to match your setup:
#   cp .env.example .env
#
# `make models` or `make quickstart` will set SWARM_MODEL automatically.

# ---------- LEVEL 1: LOCAL ----------
# Default local LLM environment: ollama | lmstudio | lm_studio
SWARM_DEFAULT_ENVIRONMENT="ollama"

# Default model — required; agents will not start without it.
# Run `make models` to auto-detect and set the best model for your hardware.
SWARM_MODEL="qwen2.5-coder:14b"

# Role-specific model tiers (optional — all fall back to SWARM_MODEL if unset)
# | Variable             | Roles                  | Example                  |
# |----------------------|------------------------|--------------------------|
# | SWARM_MODEL_PLANNING | pm, architect, ba       | deepseek-r1:14b          |
# | SWARM_MODEL_BUILD    | dev, qa                 | qwen2.5-coder:14b        |
# | SWARM_MODEL_REVIEW   | review_*, clarify       | (same as SWARM_MODEL)    |
# | SWARM_MODEL_LIGHT    | light steps / fallback  | phi-4-mini               |
# SWARM_MODEL_PLANNING="deepseek-r1:14b"
# SWARM_MODEL_BUILD="qwen2.5-coder:14b"
# SWARM_MODEL_REVIEW="qwen2.5-coder:7b"
# SWARM_MODEL_LIGHT="phi-4-mini"

# ⚠️  SECURITY: These flags give agents powerful system access.
#     Keep both set to 0 (default) unless you fully trust the pipeline.
#     NEVER enable these when the API is exposed to an untrusted network.
SWARM_ALLOW_COMMAND_EXEC=0     # 1 = agents can run shell commands
SWARM_ALLOW_WORKSPACE_WRITE=0  # 1 = agents can read/write files on disk

# Optional: per-role overrides (highest priority)
# SWARM_MODEL_PM="deepseek-r1:14b"
# SWARM_MODEL_BA="deepseek-r1:14b"
# SWARM_MODEL_ARCH="deepseek-r1:14b"
# SWARM_MODEL_DEV="qwen3-coder:30b"
# SWARM_MODEL_QA="qwen3-coder:30b"

# Бюджет токенов для Dev (OpenAI max_tokens). Без этого модель сама решает когда стоп —
# gpt-oss-20b например остановилась на 1049 токенах и выдала план вместо кода.
SWARM_DEV_MAX_OUTPUT_TOKENS=8192
# Таймаут HTTP к Ollama/LM Studio/OpenAI-compat (сек); пусто = дефолт SDK (может быть очень долго)
# SWARM_OPENAI_HTTP_TIMEOUT_SEC=720
# Повторы запроса при TimeoutException (OpenAI SDK). Для localhost/Ollama по умолчанию 0 — иначе дубль тяжёлого completion
# SWARM_OPENAI_MAX_RETRIES=2
# Не держать keep-alive к Ollama (если подозреваешь залипание соединения): 1
# SWARM_HTTPX_DISABLE_KEEPALIVE=0
# Параллельный Dev (несколько подзадач): один lock на HTTP к localhost Ollama/LM Studio — медленнее, но стабильнее
# SWARM_LOCAL_LLM_SERIALIZE=0

# Redis (TaskStore / UI task history)
# Локально: redis://localhost:6379/0. В Docker Compose бэкенд получает REDIS_URL=redis://redis:6379/0 из compose.
# REDIS_REQUIRED=0 — если Redis недоступен, InMemory (без падения). Для строгого режима в проде: REDIS_REQUIRED=1
REDIS_REQUIRED=0
# REDIS_URL=redis://localhost:6379/0
# REDIS_SOCKET_CONNECT_TIMEOUT=5
# REDIS_SOCKET_TIMEOUT=30

# ---------- LEVEL 2: CLOUD ----------
# Claude routing (Anthropic)
# ANTHROPIC_API_KEY="sk-ant-..."
# SWARM_MODEL_CLOUD="claude-3-5-sonnet-latest"
# SWARM_MODEL_CLOUD_PLANNING="claude-3-5-sonnet-latest"
# SWARM_MODEL_CLOUD_BUILD="claude-3-5-sonnet-latest"
# SWARM_MODEL_CLOUD_PM="claude-3-5-sonnet-latest"
# SWARM_MODEL_CLOUD_BA="claude-3-5-sonnet-latest"
# SWARM_MODEL_CLOUD_ARCH="claude-3-5-sonnet-latest"
# SWARM_MODEL_CLOUD_DEV="claude-3-5-sonnet-latest"
# SWARM_MODEL_CLOUD_QA="claude-3-5-sonnet-latest"

# ---------- LEVEL 3: ROUTING ----------
# local|cloud
# SWARM_ROUTE_DEFAULT="local"
# SWARM_ROUTE_PLANNING="cloud"   # PM/BA/ARCH to Claude
# SWARM_ROUTE_BUILD="local"       # DEV/QA stay on Ollama
# SWARM_ROUTE_PM="cloud"
# SWARM_ROUTE_BA="cloud"
# SWARM_ROUTE_ARCH="cloud"
# SWARM_ROUTE_DEV="local"
# SWARM_ROUTE_QA="local"

# ---------- CONTEXT BUDGET ----------
# Workspace snapshot is injected into every early pipeline node (PM, BA, etc.).
# At ~3 chars/token, the defaults below translate to roughly:
#   SWARM_WORKSPACE_MAX_BYTES=400000  →  ~133k tokens of snapshot content
#   SWARM_INPUT_MAX_CHARS=500000      →  ~167k tokens total input hard cap
#
# Context budget guidance:
#   For 128k context window: keep SWARM_WORKSPACE_MAX_BYTES <= 300000
#   For 200k context window: keep SWARM_WORKSPACE_MAX_BYTES <= 500000
#   SWARM_INPUT_MAX_CHARS acts as a hard safety cap regardless of the above —
#   it truncates the snapshot section (preserving # User task and # Project context).
#
# SWARM_WORKSPACE_MAX_BYTES=400000       # default: 400 000 bytes (~133k tokens)
# SWARM_WORKSPACE_MAX_FILES=200          # default: 200 files
# SWARM_WORKSPACE_MAX_FILE_BYTES=60000   # default: 60 000 bytes per file
# SWARM_INPUT_MAX_CHARS=500000           # default: 500 000 chars hard cap (~167k tokens)
#
# Set SWARM_LLM_CONTEXT_TOKENS to your model's context window so the system
# can warn when the estimated input exceeds 80% of the limit.
# SWARM_LLM_CONTEXT_TOKENS=128000

# ---------- REVIEWER + HUMAN ----------
# Reviewer: same routing as PM/BA/ARCH planning (SWARM_MODEL_PLANNING, SWARM_ROUTE_REVIEWER, SWARM_MODEL_REVIEWER)
# SWARM_MODEL_REVIEWER="deepseek-r1:14b"
# Human approver: 1 = auto (default, no blocking), 0 = message asks for manual confirmation in artifact
# SWARM_HUMAN_AUTO_APPROVE=1

# ---------- MCP AUTOSTART ----------
# Root workspace path — MCP servers from .swarm/mcp_config.json start automatically with the orchestrator
SWARM_WORKSPACE_ROOT=
# Set to 0 to disable MCP server autostart on orchestrator startup
SWARM_MCP_AUTOSTART=1
# SWARM_ONBOARDING_BASE_MODEL="qwen2.5-coder:7b"
# SWARM_MODEL_CONTEXT_SIZE=32768
# SWARM_MCP_MIN_TOOL_ROUNDS=6
# SWARM_MCP_TOOL_CALL_FALLBACK=1